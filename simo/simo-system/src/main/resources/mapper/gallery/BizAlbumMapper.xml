<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.simo.gallery.mapper.BizAlbumMapper">
    
    <resultMap type="BizAlbum" id="BizAlbumResult">
        <result property="albumId"    column="album_id"    />
        <result property="userId"    column="user_id"    />
        <result property="title"    column="title"    />
        <result property="description"    column="description"    />
        <result property="coverPhotoId"    column="cover_photo_id"    />
        <result property="albumType"    column="album_type"    />
        <result property="delFlag"    column="del_flag"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectBizAlbumVo">
        select album_id, user_id, title, description, cover_photo_id, album_type, del_flag, create_by, create_time, update_by, update_time, remark from biz_album
    </sql>

    <select id="selectBizAlbumList" parameterType="BizAlbum" resultMap="BizAlbumResult">
        <include refid="selectBizAlbumVo"/>
        <where>  
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="description != null  and description != ''"> and description = #{description}</if>
            <if test="coverPhotoId != null "> and cover_photo_id = #{coverPhotoId}</if>
            <if test="albumType != null  and albumType != ''"> and album_type = #{albumType}</if>
        </where>
    </select>
    
    <select id="selectBizAlbumByAlbumId" parameterType="Long" resultMap="BizAlbumResult">
        <include refid="selectBizAlbumVo"/>
        where album_id = #{albumId}
    </select>

    <insert id="insertBizAlbum" parameterType="BizAlbum" useGeneratedKeys="true" keyProperty="albumId">
        insert into biz_album
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="description != null">description,</if>
            <if test="coverPhotoId != null">cover_photo_id,</if>
            <if test="albumType != null">album_type,</if>
            <if test="delFlag != null">del_flag,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="description != null">#{description},</if>
            <if test="coverPhotoId != null">#{coverPhotoId},</if>
            <if test="albumType != null">#{albumType},</if>
            <if test="delFlag != null">#{delFlag},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateBizAlbum" parameterType="BizAlbum">
        update biz_album
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="description != null">description = #{description},</if>
            <if test="coverPhotoId != null">cover_photo_id = #{coverPhotoId},</if>
            <if test="albumType != null">album_type = #{albumType},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where album_id = #{albumId}
    </update>

    <delete id="deleteBizAlbumByAlbumId" parameterType="Long">
        delete from biz_album where album_id = #{albumId}
    </delete>

    <delete id="deleteBizAlbumByAlbumIds" parameterType="String">
        delete from biz_album where album_id in 
        <foreach item="albumId" collection="array" open="(" separator="," close=")">
            #{albumId}
        </foreach>
    </delete>
</mapper>